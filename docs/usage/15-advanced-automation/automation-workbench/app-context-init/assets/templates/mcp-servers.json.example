{
  "mcpServers": {
    "dingtalk": {
      "command": "npx",
      "args": ["-y", "mcp-dingding-bot"],
      "env": {
        "DINGTALK_BOT_ACCESS_TOKEN": "${DINGTALK_BOT_ACCESS_TOKEN}",
        "DINGTALK_BOT_SECRET": "${DINGTALK_BOT_SECRET}"
      }
    },
    "yunxiao": {
      "command": "npx",
      "args": ["-y", "alibabacloud-devops-mcp-server"],
      "env": {
        "YUNXIAO_ACCESS_TOKEN": "${YUNXIAO_ACCESS_TOKEN}"
      }
    },
    "jenkins-mcp": {
      "command": "uvx",
      "args": ["jenkins-mcp"],
      "env": {
        "JENKINS_URL": "${JENKINS_URL}",
        "JENKINS_USERNAME": "${JENKINS_USERNAME}",
        "JENKINS_PASSWORD": "${JENKINS_PASSWORD}"
      }
    },
    "mysql": {
      "command": "npx",
      "args": ["-y", "@f4ww4z/mcp-mysql-server"],
      "env": {
        "MYSQL_HOST": "${MYSQL_HOST}",
        "MYSQL_USER": "${MYSQL_USER}",
        "MYSQL_PASSWORD": "${MYSQL_PASSWORD}",
        "MYSQL_DATABASE": "${MYSQL_DATABASE}"
      }
    },
    "gitlab": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://${GITLAB_HOST}/api/v4/mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless"]
    },
    "redis": {
      "command": "uvx",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "${REDIS_URL}"
      ]
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "${GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@latest", "--read-only"]
    }
  }
}
